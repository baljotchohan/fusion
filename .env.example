# ARGUS Environment Configuration
# Copy to .env and fill in values

# ── LLM APIs ──────────────────────────────────────────
GOOGLE_API_KEY=your-gemini-api-key-here
FEATHERLESS_API_KEY=your-featherless-key-here
GROQ_API_KEY=your-groq-key-here

# ── Band AI Platform ──────────────────────────────────
# Set BAND_MOCK=false on Jun 12 after getting API key from band.ai
BAND_MOCK=true
BAND_API_KEY=get-from-band-dashboard-on-june-12

# ── App Config ────────────────────────────────────────
ARGUS_PORT=8000
LOG_LEVEL=INFO
