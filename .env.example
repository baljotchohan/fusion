# ARGUS Environment Configuration
# Copy to .env and fill in values

# ── LLM APIs (BYO keys — any one is enough) ───────────
GOOGLE_API_KEY=your-gemini-api-key-here
FEATHERLESS_API_KEY=your-featherless-key-here
GROQ_API_KEY=your-groq-key-here
AIMLAPI_KEY=your-aimlapi-key-here

# LLM router: primary provider + per-provider model overrides (optional)
ARGUS_LLM_PRIMARY=gemini
# ARGUS_AIMLAPI_MODEL=gpt-4o
# ARGUS_GROQ_MODEL=llama-3.3-70b-versatile

# ── Band AI Platform ──────────────────────────────────
# Set BAND_MOCK=false on Jun 12 after getting API key from band.ai,
# then run: python scripts/setup_band_rooms.py
BAND_MOCK=true
BAND_API_KEY=get-from-band-dashboard-on-june-12

# ── Real Connectors ───────────────────────────────────
# GitHub PAT with `security_events` scope for /api/v1/scan
GITHUB_TOKEN=your-github-pat-here

# ── App Config ────────────────────────────────────────
ARGUS_PORT=8000
LOG_LEVEL=INFO
# Frontend origin(s) allowed to call the API
ALLOWED_ORIGINS=http://localhost:3000

# ── MCP Server ────────────────────────────────────────
# Where mcp_server.py finds the running ARGUS REST API
ARGUS_API_URL=http://localhost:8000
