# ARGUS Environment Configuration
# Copy to .env and fill in values

# ── LLM APIs (hackathon partners — both used) ─────────
# Role split: AIML = conversational chat; Featherless = due-diligence analysis.
# Both run the same DeepSeek-V4-Pro model.
AIMLAPI_KEY=your-aimlapi-key-here
# Native Featherless key (rc_...). An hf_ HuggingFace token also works if you point
# ARGUS_FEATHERLESS_BASE_URL at the HF router (see below).
FEATHERLESS_API_KEY=your-featherless-rc-key-here

# Chat (core/llm_router.py): AIML primary, Featherless fallback.
ARGUS_LLM_PRIMARY=aimlapi
# ARGUS_AIMLAPI_MODEL=deepseek-v4-pro

# Analysis agents (core/base_agent.py): Featherless primary, AIML fallback, local last.
# Qwen2.5-72B is fast + non-gated. (Meta Llama is gated on Featherless; pick ONE
# model app-wide — Featherless caps model-switching at 4/min.)
# ARGUS_FEATHERLESS_MODEL=Qwen/Qwen2.5-72B-Instruct
# ARGUS_FEATHERLESS_BASE_URL=https://api.featherless.ai/v1
# (Using an hf_ token instead? use https://router.huggingface.co/featherless-ai/v1)

# ── Groq: real reasoning narrator + chat streaming ────────
# Optional and additive — never on the tool-calling critical path. One free key
# (https://console.groq.com) powers TWO things:
#   1. The "Live Reasoning" panel (core/base_agent.py): reasoning_format=parsed
#      streams real chain-of-thought deltas, separate from the answer. Without
#      this key the panel is simply absent (never faked).
#   2. Streamed Managing Partner chat (core/llm_router.py + /api/v1/chat/stream):
#      groq joins the chat fallback chain; real token deltas stream to the UI.
#      Deterministic replies stream nothing — no fake typing effects.
GROQ_API_KEY=your-groq-key-here
# ARGUS_GROQ_MODEL=openai/gpt-oss-120b
# ARGUS_GROQ_BASE_URL=https://api.groq.com/openai/v1

# ── Band AI Platform ──────────────────────────────────
# Set BAND_MOCK=false on Jun 12 after getting API key from band.ai,
# then run: python scripts/setup_band_rooms.py
BAND_MOCK=true
BAND_API_KEY=get-from-band-dashboard-on-june-12

# ── Real Connectors ───────────────────────────────────
# GitHub PAT with `security_events` scope for /api/v1/scan
GITHUB_TOKEN=your-github-pat-here

# ── App Config ────────────────────────────────────────
PORT=8000
LOG_LEVEL=INFO
# Frontend origin(s) allowed to call the API
ALLOWED_ORIGINS=http://localhost:3000

# ── Admin Dashboard ───────────────────────────────────
# Vercel personal access token + project ID for build status in /admin
VERCEL_TOKEN=your-vercel-personal-access-token
VERCEL_PROJECT_ID=your-vercel-project-id

# ── MCP Server ────────────────────────────────────────
# Where the MCP tools reach the running FUSION REST API (stdio + in-process HTTP).
FUSION_API_URL=http://localhost:8000
# Public base URL of this deployment — used to advertise the remote MCP endpoint.
FUSION_PUBLIC_URL=http://localhost:8000
# Override the advertised streamable-HTTP MCP URL (defaults to FUSION_PUBLIC_URL + /mcp).
# FUSION_MCP_URL=https://your-deploy.example.com/mcp
